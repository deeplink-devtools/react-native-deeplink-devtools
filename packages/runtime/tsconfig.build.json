{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Emit file-per-file CommonJS: the production no-op gate relies on
    // `require('./impl.js')` staying a real module boundary so Metro's
    // dead-code elimination can drop the implementation from prod bundles.
    "module": "Node16",
    "moduleResolution": "Node16",
    "verbatimModuleSyntax": false,
    "noEmit": false,
    "declaration": true,
    "sourceMap": true,
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"]
}
