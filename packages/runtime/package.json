{
  "name": "@deeplink-devtools/runtime",
  "version": "0.1.0",
  "description": "Tiny in-app deep-link reporter for React Native development builds. Guaranteed no-op in production.",
  "keywords": [
    "react-native",
    "deep-link",
    "devtools"
  ],
  "license": "MIT",
  "author": "Amrith Vengalath <amrith@vengalath.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deeplink-devtools/react-native-deeplink-devtools.git",
    "directory": "packages/runtime"
  },
  "homepage": "https://github.com/deeplink-devtools/react-native-deeplink-devtools/tree/main/packages/runtime#readme",
  "bugs": {
    "url": "https://github.com/deeplink-devtools/react-native-deeplink-devtools/issues"
  },
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./expo-router": {
      "types": "./dist/expo-router/index.d.ts",
      "default": "./dist/expo-router/index.js"
    },
    "./react-navigation": {
      "types": "./dist/react-navigation/index.d.ts",
      "default": "./dist/react-navigation/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "expo-router",
    "react-navigation"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@deeplink-devtools/core": "^0.1.0"
  },
  "peerDependencies": {
    "expo-router": ">=4",
    "react": ">=18",
    "react-native": ">=0.76"
  },
  "peerDependenciesMeta": {
    "expo-router": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "~19.2.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
